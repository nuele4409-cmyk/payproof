# PayProof — environment variables
# Copy this file to .env.local and fill in real values before running.
# Never commit .env.local to version control.

# ── Database ─────────────────────────────────────────────────────────────────
# Supabase (free Postgres at supabase.com)
# Create project → Project Settings → Database → Connection string (psql)
DATABASE_URL=postgresql://REPLACE_ME
DIRECT_URL=postgresql://REPLACE_ME

# ── Auth ──────────────────────────────────────────────────────────────────────
# Long random string used to sign JWTs. Min 32 characters.
# Generate one: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=REPLACE_WITH_A_LONG_RANDOM_STRING

# ── Monnify ───────────────────────────────────────────────────────────────────
# Get these from your Monnify sandbox dashboard → Settings → API Keys
MONNIFY_API_KEY=MK_TEST_...
MONNIFY_SECRET_KEY=...
MONNIFY_CONTRACT_CODE=...

# Sandbox (default) or live: https://api.monnify.com
MONNIFY_BASE_URL=https://sandbox.monnify.com

# Your Monnify wallet account number (Dashboard → Wallet)
MONNIFY_WALLET_ACCOUNT_NUMBER=...

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed request origins.
# Leave empty to allow all origins (fine for LOCAL dev only).
# **Set this to your real domain(s) before going to production** — an empty
# value reflects any request origin, which is only safe because auth is
# bearer-token (not cookies), but you should lock it down anyway.
# Production example: ALLOWED_ORIGINS=https://payproof.ng,https://www.payproof.ng
ALLOWED_ORIGINS=

# ── Logging ───────────────────────────────────────────────────────────────────
# Log level: debug | info | warn | error
# Defaults to "debug" in development and "info" in production.
LOG_LEVEL=debug
