generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  buyer
  seller
}

enum OrderState {
  PendingPayment
  Paid
  AwaitingShipment
  Shipped
  Delivered
  Completed
}

model User {
  id           Int      @id @default(autoincrement())
  contact      String   @unique
  name         String
  passwordHash String
  role         Role

  store    String?
  verified Boolean @default(false)

  reservedBank   String?
  reservedNumber String?
  reservedName   String?

  settlementBank   String?
  settlementNumber String?
  settlementName   String?

  typicalOrder Int?

  createdAt DateTime @default(now())

  orders   Order[]   @relation("SellerOrders")
  products Product[]

  @@index([role])
}

model Product {
  id          Int     @id @default(autoincrement())
  slug        String  @unique
  name        String
  price       Int
  description String
  image       String?

  sellerId  Int
  seller    User     @relation(fields: [sellerId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sellerId])
}

model Order {
  id  String @id
  ref String @unique

  buyer   String
  buyerId Int?
  phone   String?

  item   String
  amount Int

  state  OrderState @default(PendingPayment)

  flagged    Boolean @default(false)
  flagReason String?

  timestamps Json @default("{}")

  // Atomic claim guard for POST /api/payouts/release — set right before the
  // Monnify transfer fires, cleared on failure, never on success. Deliberately
  // separate from `state`/`timestamps` (frontend contract treats those as fixed).
  payoutClaimedAt DateTime?

  sellerId Int
  seller   User @relation("SellerOrders", fields: [sellerId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sellerId])
  @@index([state])
  @@index([sellerId, state])
}

model WebhookEvent {
  id         String   @id
  receivedAt DateTime @default(now())
  processed  Boolean  @default(false)
  payload    Json

  @@index([processed])
}
